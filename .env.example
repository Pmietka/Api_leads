# -----------------------------------------------------------------------
#  lead_tool.py — Environment Configuration
# -----------------------------------------------------------------------
#
# 1. Copy this file:
#        cp .env.example .env
#
# 2. Fill in your Google Places API key below.
#    See setup_guide.md for step-by-step instructions to create one.
#
# NOTE: Never commit your .env file to version control.
# -----------------------------------------------------------------------

# Required — Google Places API (New) key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional — override the default SQLite database path
# DB_PATH=insulation_leads.db
